local function startMainLoop()
    -- 生成循环：每2.5秒在玩家附近生成一个核弹
    task.spawn(function()
        while true do
            task.wait(2.5)
            if rootPart and #nukes < 30 then
                spawnNukeNearPlayer()
            end
        end
    end)
    
    -- 自动合并循环：每1.5秒检测一次
    task.spawn(function()
        while true do
