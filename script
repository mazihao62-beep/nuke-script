    fl.Size = UDim2.new(1, 0, 1, 0); fl.BackgroundTransparency = 1
    fl.Font = Enum.Font.SourceSansBold; fl.TextSize = 14
    fl.TextColor3 = Color3.new(1, 1, 1)
    fl.Text = "☢️ 合成核弹运行中"; fl.TextXAlignment = Enum.TextXAlignment.Center
    
    local ts = nil
    ff.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then ts = i.Position end
    end)
    ff.InputEnded:Connect(function(i)
        if ts and (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then
            if (i.Position - ts).Magnitude < 5 then mf.Visible = true; ff.Visible = false end
            ts = nil
        end
    end)
    minB.MouseButton1Click:Connect(function() mf.Visible = false; ff.Visible = true end)
    closeB.MouseButton1Click:Connect(function() sg:Destroy() end)
    
    local rb = RunService.Heartbeat:Connect(function()
        local h = (tick() * 0.3) % 1
        local c = Color3.fromHSV(h, 1, 1)
        if stroke.Parent then stroke.Color = c end
        if fs.Parent then fs.Color = c end
    end)
    sg.Destroying:Connect(function() rb:Disconnect() end)
end

