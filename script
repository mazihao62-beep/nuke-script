-- ===== 自动合并 =====
local function tryMerge()
    if not isHolding then return false end
    
    local nukes = getAllMyNukes()
    -- 检查基地中是否有同等级的核弹（至少1个，不包括我们手里拿的）
    local count = getTierCount(nukes, currentHeldTier)
    
    if count >= 1 then
        -- 找到同等级的核弹进行合并
        local target = nil
        for _, data in ipairs(nukes) do
            if data.Tier == currentHeldTier then
                target = data.Object
                break
            end
        end
        if target and target.Parent then
            local ok = pcall(function() MergeRequest:FireServer(target) end)
            if ok then
                notify("🔀 合并", "Tier " .. currentHeldTier .. " → " .. getTierName(currentHeldTier + 1))
                return true
            end
        end
    else
        -- 没有同等级核弹，丢弃当前核弹
        autoDrop()
    end
    return false
end

-- ===== 批量合并 =====
local function mergeAll()
    local count = 0
    for i = 1, 50 do
        if isHolding then
            if tryMerge() then
                count = count + 1
                task.wait(0.3)
            else
                break
            end
        else
            if autoPickup() then
                task.wait(0.2)
            else
                break
            end
        end
    end
    if count > 0 then notify("🔥 批量完成", "共合并 " .. count .. " 次")
    else notify("ℹ️ 提示", "没有可合并的核弹") end
    return count
end

-- ===== 监听服务端事件 =====
HoldStarted.OnClientEvent:Connect(function(tier)
    isHolding = true
    currentHeldTier = tier
end)

HoldEnded.OnClientEvent:Connect(function()
    isHolding = false
    currentHeldTier = 0
end)

-- ===== 主自动循环 =====
local function startAutoLoop()
    task.spawn(function()
        while true do
            task.wait(0.2)  -- 快速检测
            if not autoOn then continue end
            if not findMyBase() then continue end
            
            if isHolding then tryMerge()
            else autoPickup() end
        end
    end)
end

-- ===== 键盘快捷键 =====
UserInputService.InputBegan:Connect(function(input, gpo)
    if gpo then return end
    if input.KeyCode == Enum.KeyCode.M then
        if isHolding then tryMerge() end
    elseif input.KeyCode == Enum.KeyCode.N then
        mergeAll()
    elseif input.KeyCode == Enum.KeyCode.R then
        myBase = nil
        local n = getAllMyNukes()
        local t = getMaxTier()
        notify("🔄 已刷新", "找到 " .. #n .. " 个核弹 | 最高T" .. t)
    end
end)

