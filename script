-- ===== 常量 =====
local PICKUP_RADIUS = 7
local DROP_DEBOUNCE = 0.75
local INDIVIDUAL_DROP_DEBOUNCE = 2.5

-- ===== 状态 =====
local isHolding = false
local currentHeldTier = 0
local autoOn = true
local myBase = nil
local lastDropTime = 0
local isWalking = false
local walkTargetObj = nil
local walkTargetPos = nil
local pickupDebounce = false
local idleTimer = 0
local walkStartTime = 0

