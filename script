            local mergeable = getMergeableTiers()
            for _, data in ipairs(allNukes) do
                local t = data.Tier; distData[t] = (distData[t] or 0) + 1
                if t > maxT then maxT = t end
            end
            local heldAttr = tonumber(player:GetAttribute("HeldNukeTier")) or 0
            if heldAttr > maxT then maxT = heldAttr end
            if isHolding and currentHeldTier > maxT then maxT = currentHeldTier end
            if maxT == 0 then maxT = 1 end
            cntLbl.Text = "💣 " .. count .. " 个"
            holdLbl.Text = isHolding and "✋ 持有 T" .. currentHeldTier or "✋ 空手"
            holdLbl.TextColor3 = isHolding and Color3.fromRGB(255, 200, 50) or Color3.fromRGB(150, 255, 150)
            maxTierLbl.Text = "🏆 T" .. maxT
            if isHolding then
                local canMerge = false
                for _, data in ipairs(allNukes) do if data.Tier == currentHeldTier then canMerge = true; break end end
                statusLbl.Text = canMerge and "🔀 可合并" or "📤 待丢弃"
                statusLbl.TextColor3 = canMerge and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 200, 100)
            elseif isWalking then
                statusLbl.Text = "🚶 走向核弹"; statusLbl.TextColor3 = Color3.fromRGB(100, 200, 255)
            elseif #mergeable > 0 then
                statusLbl.Text = "🎯 T" .. mergeable[1] .. "可合并"; statusLbl.TextColor3 = Color3.fromRGB(100, 255, 100)
            else
                statusLbl.Text = count > 0 and "⏳ 无可合并" or "⏳ 等待核弹"
                statusLbl.TextColor3 = Color3.fromRGB(180, 180, 180)
            end
            local distStr = {}; local sorted = {}
            for t, _ in pairs(distData) do table.insert(sorted, t) end
            table.sort(sorted)
            for _, t in ipairs(sorted) do table.insert(distStr, "T" .. t .. ":" .. distData[t]) end
            st.Text = string.format("核弹:%d 最高:T%d\n可合并:%s\n分布:%s", count, maxT,
                #mergeable > 0 and table.concat(mergeable, " ") or "无",
                #distStr > 0 and table.concat(distStr, " ") or "无")
        end
    end)
    
    local ff = Instance.new("Frame")
    ff.Size = UDim2.new(0, 200, 0, 30); ff.Position = UDim2.new(0.5, -100, 0, 10)
    ff.BackgroundColor3 = Color3.fromRGB(35, 35, 35); ff.BackgroundTransparency = 0.1; ff.BorderSizePixel = 0
    ff.Visible = false; ff.Active = true; ff.Draggable = true; ff.Parent = sg
    Instance.new("UICorner", ff).CornerRadius = UDim.new(0, 15)
    local fs = Instance.new("UIStroke", ff); fs.Thickness = 1.5; fs.Color = Color3.fromRGB(255, 100, 100)
    local fl = Instance.new("TextLabel", ff)
    fl.Size = UDim2.new(1, 0, 1, 0); fl.BackgroundTransparency = 1
    fl.Font = Enum.Font.SourceSansBold; fl.TextSize = 14; fl.TextColor3 = Color3.new(1, 1, 1)
    fl.Text = "☢️ 合成核弹运行中"; fl.TextXAlignment = Enum.TextXAlignment.Center
    local ts = nil
    ff.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then ts = i.Position end end)
    ff.InputEnded:Connect(function(i)
        if ts and (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then
            if (i.Position - ts).Magnitude < 5 then mf.Visible = true; ff.Visible = false end; ts = nil end
    end)
    minB.MouseButton1Click:Connect(function() mf.Visible = false; ff.Visible = true end)
    closeB.MouseButton1Click:Connect(function() sg:Destroy() end)
    local rb = RunService.Heartbeat:Connect(function()
        local h = (tick() * 0.3) % 1; local c = Color3.fromHSV(h, 1, 1)
        if stroke.Parent then stroke.Color = c end; if fs.Parent then fs.Color = c end
    end)
    sg.Destroying:Connect(function() rb:Disconnect() end)
end

