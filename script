-- ===== 核弹颜色与名称 =====
local NUKE_COLORS = {
    Color3.fromRGB(180, 180, 180),
    Color3.fromRGB(80, 200, 80),
    Color3.fromRGB(50, 130, 255),
    Color3.fromRGB(150, 0, 255),
    Color3.fromRGB(255, 200, 50),
    Color3.fromRGB(255, 50, 50)
}

local TIER_NAMES = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythic"}

-- ===== 核弹管理 =====
local nukes = {}
local maxTierUnlocked = 1
local autoMergeOn = true
local spawnRate = 8

-- 创建核弹
local function createNuke(tier, pos)
    tier = math.clamp(tier, 1, 6)
    local size = 1 + tier * 0.4
    
    local part = Instance.new("Part")
    part.Size = Vector3.new(size, size, size)
    part.Shape = Enum.PartType.Ball
    part.Color = NUKE_COLORS[tier]
    part.Material = Enum.Material.Neon
    part.Anchored = false
    part.CanCollide = true
    part:SetAttribute("Tier", tier)
    part:SetAttribute("State", "floor")
    
    local bg = Instance.new("BillboardGui")
    bg.Size = UDim2.new(0, 100, 0, 30)
    bg.StudsOffset = Vector3.new(0, size + 0.5, 0)
    bg.Adornee = part
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = "⚡ Tier " .. tier
    lbl.TextColor3 = NUKE_COLORS[tier]
    lbl.Font = Enum.Font.SourceSansBold
    lbl.TextSize = 14
    lbl.TextStrokeTransparency = 0.3
    lbl.Parent = bg
    bg.Parent = part
    
    local att = Instance.new("Attachment")
    att.Parent = part
    local em = Instance.new("ParticleEmitter")
    em.Rate = 3
    em.Lifetime = NumberRange.new(0.5, 1)
    em.Speed = NumberRange.new(0.3, 0.8)
    em.SpreadAngle = Vector2.new(30, 30)
    em.Color = ColorSequence.new(NUKE_COLORS[tier])
    em.Texture = "rbxasset://textures/particles/sparkle_main.dds"
    em.Parent = att
    
    if pos then part.Position = pos end
    return part
end

-- 生成核弹
local function spawnNuke(tier, pos)
    tier = tier or math.random(1, math.min(maxTierUnlocked, 4))
    local p = pos or Vector3.new(math.random(-30, 30), 3, math.random(-30, 30))
    local nuke = createNuke(tier, p)
    nuke.Parent = Workspace
    table.insert(nukes, nuke)
    
    nuke.Size = Vector3.new(0.1, 0.1, 0.1)
    TweenService:Create(nuke, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = Vector3.new(1 + tier * 0.4, 1 + tier * 0.4, 1 + tier * 0.4)
    }):Play()
    
    return nuke
end

-- ===== 核心合并 =====
local function doMerge()
    local merged = false
    for tier = 1, 5 do
        local list = {}
        for _, n in ipairs(nukes) do
            if n and n.Parent and (n:GetAttribute("Tier") or 1) == tier and n:GetAttribute("State") == "floor" then
                table.insert(list, n)
            end
        end
        if #list >= 2 then
            local n1, n2 = list[1], list[2]
            local newTier = tier + 1
            local pos = (n1.Position + n2.Position) / 2
            
            n1:Destroy()
            n2:Destroy()
            for i = #nukes, 1, -1 do
                if nukes[i] == n1 or nukes[i] == n2 then table.remove(nukes, i) end
            end
            
            local newNuke = createNuke(newTier, pos)
            newNuke.Parent = Workspace
            newNuke:SetAttribute("State", "floor")
            table.insert(nukes, newNuke)
            
            if newTier > maxTierUnlocked then maxTierUnlocked = newTier end
            
            notify("🔀 合成成功!", "⚡ " .. TIER_NAMES[newTier] .. " Tier " .. newTier)
            merged = true
            break
        end
    end
    return merged
end

-- 批量合成
local function mergeAll()
    local count = 0
    local done = false
    repeat
        done = true
        for tier = 1, 5 do
            local list = {}
            for _, n in ipairs(nukes) do
                if n and n.Parent and (n:GetAttribute("Tier") or 1) == tier and n:GetAttribute("State") == "floor" then
                    table.insert(list, n)
                end
            end
            if #list >= 2 then
                local n1, n2 = list[1], list[2]
                local newTier = tier + 1
                local pos = (n1.Position + n2.Position) / 2
                
                n1:Destroy()
                n2:Destroy()
                for i = #nukes, 1, -1 do
                    if nukes[i] == n1 or nukes[i] == n2 then table.remove(nukes, i) end
                end
                
                local nn = createNuke(newTier, pos)
                nn.Parent = Workspace
                nn:SetAttribute("State", "floor")
                table.insert(nukes, nn)
                
                if newTier > maxTierUnlocked then maxTierUnlocked = newTier end
                count = count + 1
                done = false
                break
            end
        end
    until done
    
    if count > 0 then notify("🔀🔥 批量合成完成!", "共合成 " .. count .. " 次")
    else notify("⚠️ 提示", "没有可合成的核弹") end
    return count
end
