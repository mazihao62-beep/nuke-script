-- ===== 等级颜色 =====
local TIER_COLORS = {
    Color3.fromRGB(180, 180, 180),
    Color3.fromRGB(80, 200, 80),
    Color3.fromRGB(50, 130, 255),
    Color3.fromRGB(150, 0, 255),
    Color3.fromRGB(255, 200, 50),
    Color3.fromRGB(255, 50, 50)
}
local TIER_NAMES = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythic"}

-- ===== 全局状态 =====
local myNukesFolder = nil  -- 玩家的核弹文件夹
local autoOn = true
local mergeCooldown = 0

-- ===== 查找玩家的核弹文件夹（源码findMyNukesFolder逻辑） =====
local function findMyNukesFolder()
    if myNukesFolder and myNukesFolder.Parent then
        return myNukesFolder
    end
    myNukesFolder = nil
    
    local bases = Workspace:FindFirstChild("Bases")
    if not bases then return nil end
    
    for _, base in ipairs(bases:GetChildren()) do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            for _, nuke in ipairs(nukes:GetChildren()) do
                if nuke:GetAttribute("OwnerUserId") == player.UserId then
                    myNukesFolder = nukes
                    return nukes
                end
            end
        end
    end
    return nil
end

-- ===== 获取玩家基地中所有真实核弹 =====
local function getMyNukes()
    local folder = findMyNukesFolder()
    if not folder then return {} end
    
    local list = {}
    for _, child in ipairs(folder:GetChildren()) do
        if (child:IsA("BasePart") or child:IsA("Model")) and child:GetAttribute("Tier") then
            table.insert(list, child)
        end
    end
    return list
end

-- ===== 核心：合并两个同等级的真实核弹 =====
local function tryMerge()
    local now = os.clock()
    if now < mergeCooldown then return false end
    
    local nukes = getMyNukes()
    if #nukes < 2 then return false end
    
    -- 从低到高遍历等级
    for tier = 1, 5 do
        local sameTier = {}
        for _, n in ipairs(nukes) do
            if n:GetAttribute("Tier") == tier then
                table.insert(sameTier, n)
            end
        end
        
        if #sameTier >= 2 then
            local target = sameTier[1]
            
            -- 调用服务端合并接口（源码MergeRequest:FireServer逻辑）
            local success = pcall(function()
                MergeRequest:FireServer(target)
            end)
            
            if success then
                mergeCooldown = now + 0.3
                notify("🔀 合并请求已发送", "Tier " .. tier .. " → " .. TIER_NAMES[tier])
                return true
            end
        end
    end
    return false
end

-- ===== 批量合并 =====
local function mergeAll()
    local count = 0
    local maxAttempts = 30  -- 防止死循环
    for i = 1, maxAttempts do
        if tryMerge() then
            count = count + 1
            task.wait(0.1)
        else
            break
        end
    end
    if count > 0 then
        notify("🔥 批量完成", "共发送 " .. count .. " 次合并请求")
    else
        notify("ℹ️ 提示", "没有可合并的核弹")
    end
    return count
end
