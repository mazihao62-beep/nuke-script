local TIER_COLORS = {
    Color3.fromRGB(180, 180, 180),  -- 1 Common
    Color3.fromRGB(80, 200, 80),    -- 2 Uncommon
    Color3.fromRGB(50, 130, 255),   -- 3 Rare
    Color3.fromRGB(150, 0, 255),    -- 4 Epic
    Color3.fromRGB(255, 200, 50),   -- 5 Legendary
    Color3.fromRGB(255, 50, 50)     -- 6 Mythic
}

local TIER_NAMES = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythic"}

-- ===== 全局状态 =====
local nukes = {}          -- 场景中所有核弹
local maxTier = 1         -- 当前最高解锁等级
local autoOn = true       -- 自动合成开关

-- ===== 创建核弹模型（源码Apache_Commander_Animate风格） =====
local function makeNuke(tier, pos)
    tier = math.clamp(tier, 1, 6)
    local size = 1 + tier * 0.4
    
    local p = Instance.new("Part")
    p.Name = "Nuke"
    p.Size = Vector3.new(size, size, size)
    p.Shape = Enum.PartType.Ball
    p.Color = TIER_COLORS[tier]
    p.Material = Enum.Material.Neon
    p.Anchored = false
    p.CanCollide = true
    p.CanTouch = true
    
    -- 属性标记（源码用Attribute标记Tier和State）
    p:SetAttribute("Tier", tier)
    p:SetAttribute("State", "floor")
    
    if pos then p.Position = pos end
    
    -- 等级标签（BillboardGui）
    local bg = Instance.new("BillboardGui")
    bg.Name = "TierTag"
    bg.Size = UDim2.new(0, 100, 0, 30)
    bg.StudsOffset = Vector3.new(0, size + 0.5, 0)
    bg.Adornee = p
    bg.AlwaysOnTop = true
    
    local lbl = Instance.new("TextLabel", bg)
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = "Tier " .. tier
    lbl.TextColor3 = TIER_COLORS[tier]
    lbl.Font = Enum.Font.SourceSansBold
    lbl.TextSize = 14
    lbl.TextStrokeTransparency = 0.3
    bg.Parent = p
    
    -- 粒子特效（源码ParticleEmitter风格）
    local att = Instance.new("Attachment", p)
    local em = Instance.new("ParticleEmitter", att)
    em.Rate = 3
    em.Lifetime = NumberRange.new(0.5, 1)
    em.Speed = NumberRange.new(0.3, 0.8)
    em.SpreadAngle = Vector2.new(30, 30)
    em.Color = ColorSequence.new(TIER_COLORS[tier])
    em.Texture = "rbxasset://textures/particles/sparkle_main.dds"
    em.Enabled = true
    
    return p
end

-- ===== 在玩家附近生成核弹 =====
local function spawnNukeNearPlayer()
    if not rootPart then return nil end
    
    local tier = math.random(1, math.min(maxTier, 3))
    local angle = math.random() * math.pi * 2
    local dist = math.random(5, 15)
    local pos = rootPart.Position + Vector3.new(
        math.cos(angle) * dist,
        2,
        math.sin(angle) * dist
    )
    
    local n = makeNuke(tier, pos)
    n.Parent = Workspace
    table.insert(nukes, n)
    
    -- 出生缩放动画
    n.Size = Vector3.new(0.1, 0.1, 0.1)
    local tween = TweenService:Create(n, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = Vector3.new(1 + tier * 0.4, 1 + tier * 0.4, 1 + tier * 0.4)
    })
    tween:Play()
    
    return n
end
