function getTierName(t)
    return TIER_NAMES[t] or "Tier " .. t
end

function getTierColor(t)
    return TIER_COLORS[t] or Color3.fromHSV((t * 0.15) % 1, 1, 1)
end

-- ===== 获取我的基地 =====
local function findMyBase()
    if myBase and myBase.Parent then return myBase end
    myBase = nil
    local bases = Workspace:FindFirstChild("Bases")
    if not bases then return nil end
    for _, base in ipairs(bases:GetChildren()) do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            for _, child in ipairs(nukes:GetChildren()) do
                if child:GetAttribute("OwnerUserId") == player.UserId then
                    myBase = base
                    return base
                end
            end
        end
    end
    return nil
end

-- ===== 获取我的所有核弹 =====
local function getAllMyNukes()
    local base = findMyBase()
    if not base then return {} end
    local nukes = base:FindFirstChild("Nukes")
    if not nukes then return {} end
    local list = {}
    for _, child in ipairs(nukes:GetChildren()) do
        if (child:IsA("BasePart") or child:IsA("Model")) and child:GetAttribute("OwnerUserId") == player.UserId then
            local tier = child:GetAttribute("Tier") or 1
            table.insert(list, {Object = child, Tier = tier})
        end
    end
    return list
end

-- ===== 获取基地中某个等级的数量 =====
local function getTierCount(nukesList, tier)
    local count = 0
    for _, data in ipairs(nukesList) do
        if data.Tier == tier then count = count + 1 end
    end
    return count
end

-- ===== 获取最高等级 =====
local function getMaxTier()
    local allNukes = getAllMyNukes()
    local maxT = 0
    for _, data in ipairs(allNukes) do
        if data.Tier > maxT then maxT = data.Tier end
    end
    local heldAttr = player:GetAttribute("HeldNukeTier") or 0
    if heldAttr > maxT then maxT = heldAttr end
    if isHolding and currentHeldTier > maxT then maxT = currentHeldTier end
    return math.max(1, maxT)
end

-- ===== 找第一个可拾取的核弹（无距离限制） =====
local function findPickupTarget()
    local base = findMyBase()
    if not base then return nil end
    local nukesFolder = base:FindFirstChild("Nukes")
    if not nukesFolder then return nil end
    
    for _, child in ipairs(nukesFolder:GetChildren()) do
        if (child:IsA("BasePart") or child:IsA("Model")) then
            local ownerId = child:GetAttribute("OwnerUserId")
            local state = child:GetAttribute("State")
            if ownerId == player.UserId and (state == "floor" or state == "based") then
                return child
            end
        end
    end
    return nil
end

-- ===== 自动拾取 =====
local function autoPickup()
    if isHolding then return false end
    if not findMyBase() then return false end
    
    local nukes = getAllMyNukes()
    -- 找最低等级的核弹拾取（更容易找到同等级合并）
    local minTier = 999
    local target = nil
    for _, data in ipairs(nukes) do
        if data.Tier < minTier then
            minTier = data.Tier
            target = data.Object
        end
    end
    
    if target then
        local ok = pcall(function() PickUp:FireServer(target) end)
        if ok then
            notify("📥 拾取", "Tier " .. minTier)
            return true
        end
    end
    return false
end

-- ===== 自动丢弃（手里核弹无法合并时丢掉） =====
local function autoDrop()
    if not isHolding then return false end
    local ok = pcall(function() Drop:FireServer() end)
    if ok then
        notify("📤 丢弃", "Tier " .. currentHeldTier .. " 无可合并对象")
        isHolding = false
        currentHeldTier = 0
        return true
    end
    return false
end
