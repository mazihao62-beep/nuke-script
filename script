-- ===== 自动合并循环（修复：更稳定的循环逻辑） =====
local function startAutoMerge()
    task.spawn(function()
        while true do
            task.wait(3)  -- 每3秒检测一次
            
            if not autoOn then continue end
            
            -- 检查是否找到基地
            local folder = findMyNukesFolder()
            if not folder then continue end
            
            local nukes = getMyNukes()
            if #nukes < 2 then continue end
            
            -- 尝试合并一次，成功后等待1秒再试
            if tryMerge() then
                task.wait(1)
            end
        end
    end)
end

