local TIER_NAMES = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythic"}
local TIER_COLORS = {
    Color3.fromRGB(180, 180, 180),
    Color3.fromRGB(80, 200, 80),
    Color3.fromRGB(50, 130, 255),
    Color3.fromRGB(150, 0, 255),
    Color3.fromRGB(255, 200, 50),
    Color3.fromRGB(255, 50, 50)
}

-- ===== 全局状态 =====
local myNukesFolder = nil
local autoOn = true
local mergeCooldown = 0

-- ===== 查找玩家核弹文件夹（源码findMyNukesFolder精确实现） =====
local function findMyNukesFolder()
    if myNukesFolder and myNukesFolder.Parent then
        return myNukesFolder
    end
    myNukesFolder = nil
    
    local bases = Workspace:FindFirstChild("Bases")
    if not bases then return nil end
    
    for _, base in ipairs(bases:GetChildren()) do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            -- 检查该Nukes文件夹下是否有属于玩家的核弹
            for _, child in ipairs(nukes:GetChildren()) do
                if child:GetAttribute("OwnerUserId") == player.UserId then
                    myNukesFolder = nukes
                    return nukes
                end
            end
        end
    end
    return nil
end

-- ===== 获取玩家所有真实核弹（修复：更健壮的检测） =====
local function getMyNukes()
    local folder = findMyNukesFolder()
    if not folder then return {} end
    
    local list = {}
    for _, child in ipairs(folder:GetChildren()) do
        -- 核弹可以是BasePart或Model（源码支持两种类型）
        local isValid = false
        if child:IsA("BasePart") then
            isValid = true
        elseif child:IsA("Model") then
            isValid = true
        end
        
        if isValid then
            -- 获取等级，支持数字和字符串两种格式
            local tier = child:GetAttribute("Tier")
            if tier then
                tier = tonumber(tier)
                if tier and tier >= 1 and tier <= 6 then
                    table.insert(list, {
                        Object = child,
                        Tier = tier
                    })
                end
            end
        end
    end
    return list
end

-- ===== 获取玩家基地中最高等级 =====
local function getMaxTier()
    local nukes = getMyNukes()
    local maxT = 0
    for _, data in ipairs(nukes) do
        if data.Tier > maxT then
            maxT = data.Tier
        end
    end
    return maxT
end

-- ===== 核心：合并两个同等级真实核弹（源码tryDetect逻辑） =====
local function tryMerge()
    local now = os.clock()
    if now < mergeCooldown then return false end
    
    local nukes = getMyNukes()
    if #nukes < 2 then return false end
    
    -- 先按等级分组
    local tierGroups = {}
    for _, data in ipairs(nukes) do
        tierGroups[data.Tier] = tierGroups[data.Tier] or {}
        table.insert(tierGroups[data.Tier], data.Object)
    end
    
    -- 从低到高找第一个有2个以上同等级的
    for tier = 1, 5 do
        local group = tierGroups[tier]
        if group and #group >= 2 then
            local target = group[1]
            
            -- 检查目标对象是否还存在
            if target and target.Parent then
                local success = pcall(function()
                    MergeRequest:FireServer(target)
                end)
                
                if success then
                    -- 源码中使用0.5秒冷却
                    mergeCooldown = now + 0.8
                    notify("🔀 合并请求", "Tier " .. tier .. " → 升级中...")
                    return true
                end
            end
        end
    end
    
    return false
end

-- ===== 批量合并（带间隔，防止服务器限流） =====
local function mergeAll()
    local count = 0
    for i = 1, 20 do  -- 最多20次，防止死循环
        if tryMerge() then
            count = count + 1
            task.wait(0.8)  -- 每次合并间隔0.8秒，避免被服务器限流
        else
            break
        end
    end
    if count > 0 then
        notify("🔥 批量完成", "共发送 " .. count .. " 次合并请求")
    else
        notify("ℹ️ 提示", "没有可合并的核弹")
    end
    return count
end
