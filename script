-- ===== 清理无效核弹引用 =====
local function cleanNukes()
    for i = #nukes, 1, -1 do
        local n = nukes[i]
        if not n or not n.Parent then
            table.remove(nukes, i)
        end
    end
end

-- ===== 核心：合并两个同等级核弹（源码MergeController逻辑） =====
local function tryMerge()
    cleanNukes()
    if #nukes < 2 then return false end
    
    -- 从低到高遍历等级
    for tier = 1, 5 do
        local list = {}
        for _, n in ipairs(nukes) do
            if n:GetAttribute("Tier") == tier and n:GetAttribute("State") == "floor" then
                table.insert(list, n)
            end
        end
        
        if #list >= 2 then
            local n1 = list[1]
            local n2 = list[2]
            local newTier = tier + 1
            
            -- 取两个核弹的中点位置
            local pos = (n1.Position + n2.Position) / 2
            
            -- 销毁旧的
            n1:Destroy()
            n2:Destroy()
            for i = #nukes, 1, -1 do
                if nukes[i] == n1 or nukes[i] == n2 then
                    table.remove(nukes, i)
                end
            end
            
            -- 创建新的更高等级核弹
            local nn = makeNuke(newTier, pos)
            nn.Parent = Workspace
            table.insert(nukes, nn)
            
            -- 更新最高等级
            if newTier > maxTier then
                maxTier = newTier
            end
            
            notify("🔀 合成成功", TIER_NAMES[newTier] .. " Tier " .. newTier)
            return true
        end
    end
    
    return false
end

-- ===== 批量合成（一直合到不能合为止） =====
local function mergeAll()
    cleanNukes()
    local count = 0
    
    while tryMerge() do
        count = count + 1
    end
    
    if count > 0 then
        notify("🔥 批量完成", "共合成 " .. count .. " 次")
    else
        notify("ℹ️ 提示", "没有可合成的核弹")
    end
    
    return count
end

-- ===== 角色绑定（源码CharacterAdded事件） =====
local function onCharacterAdded(char)
    character = char
    rootPart = char:WaitForChild("HumanoidRootPart", 5)
    
    if not rootPart then
        character = nil
        warn("[合成核弹] 角色没有HumanoidRootPart")
        return
    end
    
    -- 监听死亡，死亡时清空引用
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum.Died:Connect(function()
            character = nil
            rootPart = nil
        end)
    end
end

-- 绑定当前角色和未来角色
if player.Character then
    onCharacterAdded(player.Character)
end
player.CharacterAdded:Connect(onCharacterAdded)

-- ===== 键盘快捷键 =====
UserInputService.InputBegan:Connect(function(input, gpo)
    if gpo then return end
    
    if input.KeyCode == Enum.KeyCode.M then
        tryMerge()
    elseif input.KeyCode == Enum.KeyCode.N then
        mergeAll()
    end
end)

