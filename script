-- ===== 自动合并循环 =====
local function startAutoMerge()
    task.spawn(function()
        while true do
            task.wait(2)
            if autoMergeOn then
                local any = false
                repeat any = doMerge() until not any
            end
        end
    end)
end

-- ===== 生成循环 =====
local function startSpawnLoop()
    task.spawn(function()
        while true do
            task.wait(1)
            if #nukes < 40 and math.random(1, spawnRate) == 1 then
                local weights = {}
                local maxT = math.min(maxTierUnlocked, 4)
                for t = 1, maxT do
                    for _ = 1, maxT - t + 1 do table.insert(weights, t) end
                end
                spawnNuke(weights[math.random(1, #weights)])
            end
        end
    end)
end

-- ===== 清理无效核弹 =====
local function cleanNukes()
    for i = #nukes, 1, -1 do
        if not nukes[i] or not nukes[i].Parent then table.remove(nukes, i) end
    end
end

