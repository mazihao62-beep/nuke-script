-- ===== 自动合并循环 =====
local function startAutoMerge()
    task.spawn(function()
        while true do
            task.wait(2)
            if autoOn then
                local merged = false
                repeat
                    merged = tryMerge()
                    if merged then task.wait(0.3) end
                until not merged
            end
        end
    end)
end

-- ===== 键盘快捷键 =====
UserInputService.InputBegan:Connect(function(input, gpo)
    if gpo then return end
    if input.KeyCode == Enum.KeyCode.M then
        tryMerge()
    elseif input.KeyCode == Enum.KeyCode.N then
        mergeAll()
    end
end)

