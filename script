    t1.TextXAlignment = Enum.TextXAlignment.Left
    t1.Text = title
    t1.ZIndex = 101
    
    local t2 = Instance.new("TextLabel", n)
    t2.Size = UDim2.new(1, -16, 0, 18)
    t2.Position = UDim2.new(0, 8, 0, 30)
    t2.BackgroundTransparency = 1
    t2.Font = Enum.Font.SourceSans
    t2.TextSize = 13
    t2.TextColor3 = Color3.fromRGB(220, 220, 220)
    t2.TextXAlignment = Enum.TextXAlignment.Left
    t2.Text = text
    t2.ZIndex = 101
    
    -- 滑入动画
    n.Position = UDim2.new(1, 240, 1, -10)
    TweenService:Create(n, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -230, 1, -10)
    }):Play()
    
    -- 延迟滑出销毁
    task.delay(dur, function()
        if not n.Parent then return end
        local ot = TweenService:Create(n, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 240, 1, -10)
        })
        ot:Play()
        ot.Completed:Once(function()
            if n.Parent then n:Destroy() end
        end)
    end)
end

