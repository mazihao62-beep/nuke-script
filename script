-- ===== 先用最安全的方式获取远程事件 =====
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- 方案1: 从Packages.Remotes模块获取（这是源码的方式）
local MergeRequest = nil
local Packages = ReplicatedStorage:FindFirstChild("Packages")
if Packages then
    local RemotesMod = Packages:FindFirstChild("Remotes")
    if RemotesMod and RemotesMod:IsA("ModuleScript") then
        local ok, result = pcall(require, RemotesMod)
        if ok and type(result) == "table" then
            MergeRequest = result.MergeRequest
        end
    end
end

-- 方案2: 如果方案1不行，直接从RemoteEvents找
if MergeRequest == nil then
    local RemoteEvents = ReplicatedStorage:FindFirstChild("RemoteEvents")
    if RemoteEvents then
        MergeRequest = RemoteEvents:FindFirstChild("MergeRequest")
    end
end

