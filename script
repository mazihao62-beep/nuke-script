-- ===== 工具 =====
local TIER_NAMES = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythic"}
local TIER_COLORS = {Color3.fromRGB(180, 180, 180), Color3.fromRGB(80, 200, 80), Color3.fromRGB(50, 130, 255), Color3.fromRGB(150, 0, 255), Color3.fromRGB(255, 200, 50), Color3.fromRGB(255, 50, 50)}
local function getTierColor(t) return TIER_COLORS[t] or Color3.fromHSV((t * 0.15) % 1, 1, 1) end

local function findMyBase()
    if myBase and myBase.Parent then return myBase end
    myBase = nil
    local bases = Workspace:FindFirstChild("Bases")
    if not bases then return nil end
    for _, base in ipairs(bases:GetChildren()) do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            for _, child in ipairs(nukes:GetChildren()) do
                if child:GetAttribute("OwnerUserId") == player.UserId then
                    myBase = base; return base
                end
            end
        end
    end
    return nil
end

local function getAllMyNukes()
    local base = findMyBase()
    if not base then return {} end
    local nukesFolder = base:FindFirstChild("Nukes")
    if not nukesFolder then return {} end
    local list = {}
    for _, child in ipairs(nukesFolder:GetChildren()) do
        if child:IsA("BasePart") or child:IsA("Model") then
            if child:GetAttribute("OwnerUserId") == player.UserId then
                local tier = tonumber(child:GetAttribute("Tier")) or 1
                local state = child:GetAttribute("State") or ""
                local dropTime = child:GetAttribute("DropTime")
                table.insert(list, {Object = child, Tier = tier, State = state, DropTime = dropTime})
            end
        end
    end
    return list
end

local function getNukePos(nuke)
    if nuke:IsA("Model") then
        local ok, pivot = pcall(function() return nuke:GetPivot() end)
        if ok then return pivot.Position end
    end
    return nuke.Position
end

local function getPlayerPos()
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    return root and root.Position
end

local function stopMoving()
    local char = player.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum:WalkToPoint = Vector3.new() end
    end
    isWalking = false; walkTargetObj = nil; walkTargetPos = nil
end

local function moveTo(pos)
    if not pos then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then hum:MoveTo(pos) end
end

local function getMergeableTiers()
    local allNukes = getAllMyNukes()
    local tierCounts = {}
    for _, data in ipairs(allNukes) do
        if data.State == "floor" or data.State == "based" then
            local ok = true
            if data.DropTime then ok = (Workspace:GetServerTimeNow() - data.DropTime) >= INDIVIDUAL_DROP_DEBOUNCE end
            if ok then tierCounts[data.Tier] = (tierCounts[data.Tier] or 0) + 1 end
        end
    end
    local result = {}
    for t, c in pairs(tierCounts) do if c >= 2 then table.insert(result, t) end end
    table.sort(result)
    return result
end
-- ===== 核心功能（每个调用都保护） =====

local function walkToMergeableNuke()
    if isHolding then stopMoving(); return false end
    if pickupDebounce then return false end
    local pos = getPlayerPos()
    if not pos then return false end
    local mergeable = getMergeableTiers()
    if #mergeable == 0 then return false end
    local targetTier = mergeable[1]
    local allNukes = getAllMyNukes()
    local bestObj = nil; local bestDist = 999
    for _, data in ipairs(allNukes) do
        if data.Tier == targetTier and (data.State == "floor" or data.State == "based") then
            local ok = true
            if data.DropTime then ok = (Workspace:GetServerTimeNow() - data.DropTime) >= INDIVIDUAL_DROP_DEBOUNCE end
            if ok then
                local np = getNukePos(data.Object)
                local dx = np.X - pos.X; local dz = np.Z - pos.Z
                local dist = math.sqrt(dx * dx + dz * dz)
                if dist < bestDist then bestObj = data.Object; bestDist = dist end
            end
        end
    end
    if bestObj and bestObj.Parent then
        local np = getNukePos(bestObj)
        local dx = np.X - pos.X; local dz = np.Z - pos.Z
        local dist = math.sqrt(dx * dx + dz * dz)
        if dist <= PICKUP_RADIUS then stopMoving(); return false end
        walkTargetObj = bestObj; walkTargetPos = np; walkStartTime = os.clock()
        isWalking = true; moveTo(np); return true
    end
    return false
end

local function tryPickup()
    if isHolding then return false end
    if pickupDebounce then return false end
    if os.clock() - lastDropTime < DROP_DEBOUNCE then return false end
    local pos = getPlayerPos()
    if not pos then return false end
    local allNukes = getAllMyNukes()
    local mergeableMap = {}
    for _, t in ipairs(getMergeableTiers()) do mergeableMap[t] = true end
    local bestObj = nil; local bestDist = PICKUP_RADIUS
    for _, data in ipairs(allNukes) do
        if data.State == "floor" or data.State == "based" then
            local ok = true
            if data.DropTime then ok = (Workspace:GetServerTimeNow() - data.DropTime) >= INDIVIDUAL_DROP_DEBOUNCE end
            if ok then
                local np = getNukePos(data.Object)
                local dx = np.X - pos.X; local dz = np.Z - pos.Z
                local dist = math.sqrt(dx * dx + dz * dz)
                if dist <= bestDist then
                    if mergeableMap[data.Tier] then bestObj = data.Object; bestDist = dist
                    elseif bestObj == nil then bestObj = data.Object; bestDist = dist end
                end
            end
        end
    end
    if bestObj then
        pickupDebounce = true
        if PickUp then
            local ok = pcall(function() PickUp:FireServer(bestObj) end)
            if ok then
                local tier = tonumber(bestObj:GetAttribute("Tier")) or 1
                notify("📥 拾取", "Tier " .. tier)
                stopMoving()
                task.delay(0.4, function() pickupDebounce = false end)
                return true
            end
        end
        pickupDebounce = false
    end
    return false
end

local function tryMerge()
    if not isHolding then return false end
    local nukes = getAllMyNukes()
    local target = nil
    for _, data in ipairs(nukes) do
        if data.Tier == currentHeldTier then target = data.Object; break end
    end
    if target and target.Parent then
        if MergeRequest then
            local ok = pcall(function() MergeRequest:FireServer(target) end)
            if ok then
                stopMoving()
                notify("🔀 合并", "Tier " .. currentHeldTier)
                return true
            end
        end
    else
        if Drop then pcall(function() Drop:FireServer() end) end
        isHolding = false; currentHeldTier = 0; lastDropTime = os.clock()
        stopMoving()
        notify("📤 丢弃", "无可合并对象")
    end
    return false
end

local function mergeAll()
    local count = 0
    for i = 1, 50 do
        if isHolding then
            if tryMerge() then count = count + 1; task.wait(0.2) else break end
        else
            if tryPickup() then task.wait(0.2) else walkToMergeableNuke(); task.wait(0.5) end
        end
    end
    if count > 0 then notify("🔥 批量完成", "共合并 " .. count .. " 次")
    else notify("ℹ️ 提示", "没有可合并的核弹") end
    return count
end

if HoldStarted then
    HoldStarted.OnClientEvent:Connect(function(tier)
        isHolding = true; currentHeldTier = tonumber(tier) or tier; stopMoving()
    end)
end

if HoldEnded then
    HoldEnded.OnClientEvent:Connect(function()
        lastDropTime = os.clock(); isHolding = false; currentHeldTier = 0; stopMoving()
    end)
end

local function startAutoLoop()
    task.spawn(function()
        while true do
            task.wait(0.1)
            local canRun = autoOn and (findMyBase() ~= nil) and (os.clock() - lastDropTime >= DROP_DEBOUNCE)
            if canRun then
                if isHolding then tryMerge()
                else
                    if isWalking then
                        local needStop = false
                        if walkTargetObj == nil or walkTargetPos == nil then needStop = true
                        elseif walkTargetObj.Parent == nil then needStop = true
                        else
                            local np = getPlayerPos()
                            if np then
                                local dx = walkTargetPos.X - np.X; local dz = walkTargetPos.Z - np.Z
                                local dist = math.sqrt(dx * dx + dz * dz)
                                if dist <= PICKUP_RADIUS then needStop = true
                                elseif os.clock() - walkStartTime > 5 then needStop = true end
                            end
                        end
                        if needStop then stopMoving() end
                    end
                    local picked = tryPickup()
                    if picked then idleTimer = 0
                    else
                        local walked = walkToMergeableNuke()
                        if walked then idleTimer = 0
                        else
                            idleTimer = idleTimer + 1
                            if idleTimer >= 50 then task.wait(1); idleTimer = 0 end
                        end
                    end
                end
            end
        end
    end)
end

UserInputService.InputBegan:Connect(function(input, gpo)
    if gpo then return end
    if input.KeyCode == Enum.KeyCode.M then if isHolding then tryMerge() end end
    if input.KeyCode == Enum.KeyCode.N then mergeAll() end
    if input.KeyCode == Enum.KeyCode.R then
        myBase = nil; stopMoving()
        if findMyBase() then local n = getAllMyNukes(); notify("🔄 已刷新", "找到 " .. #n .. " 个核弹")
        else notify("⚠️ 未找到基地") end
    end
end)

