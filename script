-- ===== 获取最高等级（源码localMaxTier精确实现 + HeldNukeTier） =====
local function getMaxTier()
    local bases = Workspace:FindFirstChild("Bases")
    local v41 = 0
    if bases then
        for _, base in ipairs(bases:GetChildren()) do
            local nukes = base:FindFirstChild("Nukes")
            if nukes then
                for _, child in ipairs(nukes:GetChildren()) do
                    if (child:IsA("BasePart") or child:IsA("Model")) and child:GetAttribute("OwnerUserId") == player.UserId then
                        local tier = child:GetAttribute("Tier") or 0
                        if v41 < tier then v41 = tier end
                    end
                end
            end
        end
    end
    -- 源码：检查玩家身上的HeldNukeTier属性（服务端设置）
    local v46 = player:GetAttribute("HeldNukeTier") or 0
    if v41 >= v46 then v46 = v41 end
    if v46 == 0 and isHolding then v46 = currentHeldTier end
    return math.max(1, v46)
end

-- ===== 获取所有核弹列表 =====
local function getAllMyNukes()
    local bases = Workspace:FindFirstChild("Bases")
    if not bases then return {} end
    local list = {}
    for _, base in ipairs(bases:GetChildren()) do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            for _, child in ipairs(nukes:GetChildren()) do
                if (child:IsA("BasePart") or child:IsA("Model")) and child:GetAttribute("OwnerUserId") == player.UserId then
                    local tier = child:GetAttribute("Tier") or 1
                    table.insert(list, {Object = child, Tier = tier})
                end
            end
        end
    end
    return list
end

-- ===== 找可拾取的目标（源码findPickupTarget逻辑） =====
local function findPickupTarget()
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local bases = Workspace:FindFirstChild("Bases")
    if not bases then return nil end
    
    local closest = nil
    local closestDist = 15
    
    for _, base in ipairs(bases:GetChildren()) do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            for _, child in ipairs(nukes:GetChildren()) do
                if (child:IsA("BasePart") or child:IsA("Model")) then
                    local ownerId = child:GetAttribute("OwnerUserId")
                    if ownerId == player.UserId then
                        local state = child:GetAttribute("State")
                        if state == "floor" or state == "based" then
                            local dropTime = child:GetAttribute("DropTime")
                            if not dropTime or Workspace:GetServerTimeNow() - dropTime >= 1 then
                                local pos = child:IsA("Model") and child:GetPivot().Position or child.Position
                                local dx = pos.X - root.Position.X
                                local dz = pos.Z - root.Position.Z
                                local dist = math.sqrt(dx * dx + dz * dz)
                                if dist <= closestDist then
                                    closest = child
                                    closestDist = dist
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return closest
end

-- ===== 自动拾取 =====
local function autoPickup()
    local now = os.clock()
    if now < pickupCD then return false end
    if isHolding then return false end
    
    local target = findPickupTarget()
    if target then
        pickupCD = now + 0.5
        local ok = pcall(function() PickUp:FireServer(target) end)
        if ok then
            notify("📥 自动拾取", "拾取核弹中...")
            return true
        end
    end
    return false
end

-- ===== 自动合并（源码MergeController逻辑） =====
local function tryMerge()
    local now = os.clock()
    if now < mergeCD then return false end
    if not isHolding then return false end
    
    local nukes = getAllMyNukes()
    local target = nil
    for _, data in ipairs(nukes) do
        if data.Tier == currentHeldTier then
            target = data.Object
            break
        end
    end
    
    if target and target.Parent then
        mergeCD = now + 1
        local ok = pcall(function() MergeRequest:FireServer(target) end)
        if ok then
            notify("🔀 自动合并", "Tier " .. currentHeldTier .. " 合并中...")
            return true
        end
    end
    return false
end
