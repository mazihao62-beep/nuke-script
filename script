-- ===== 批量合并 =====
local function mergeAll()
    local count = 0
    for i = 1, 30 do
        if isHolding then
            if tryMerge() then count = count + 1; task.wait(1.5)
            else break end
        else
            if autoPickup() then task.wait(1)
            else break end
        end
    end
    if count > 0 then notify("🔥 批量完成", "共合并 " .. count .. " 次")
    else notify("ℹ️ 提示", "没有可合并的核弹") end
    return count
end

